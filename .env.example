# -----------------------------------------------------------------------------
# Neo B2-Plus Gateway: Environment Configuration
# All primary configuration is done via config.json.
# These env vars are optional overrides, mainly for Docker deployments.
# -----------------------------------------------------------------------------

# ENVIRONMENT (development | production)
APP_ENV=production
SERVER_PORT=8080

# DATABASE (Postgres)
# If using docker-compose, host is 'db'
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=neob2plus
DATABASE_URL=host=localhost user=postgres password=your_secure_password dbname=neob2plus port=5432 sslmode=disable

# MONITORING / ALERTS (Optional)
# Discord Webhook URL for real-time alerting (can also be set in config.json)
DISCORD_WEBHOOK_URL=
